{
  "colors": {
    "primary": {
      "hex": "#abd5f4",
      "name": "Brand Blue",
      "usage": "Primary buttons, accents, icons"
    },
    "secondary": {
      "hex": "#ff9651",
      "name": "Brand Orange",
      "usage": "Secondary buttons, highlights, indicators"
    },
    "accent": {
      "hex": "#ff9651",
      "name": "Accent Orange",
      "usage": "Highlights, emphasis"
    },
    "link": {
      "base": "#36afeb",
      "hover": "#1e85c8"
    },
    "text": {
      "heading": "#333333",
      "body": "#666666",
      "emphasis": "#000000",
      "muted": "#999999"
    },
    "background": {
      "page": "#ffffff",
      "muted": "#f8f8f8",
      "primary": "#e1f0fb"
    },
    "border": {
      "divider": "#e5e5e5",
      "indicator": "#ff9651"
    }
  },
  "typography": {
    "fonts": {
      "body": {
        "family": "'Nunito Sans', sans-serif",
        "weights": [300, 400]
      },
      "heading": {
        "family": "Roboto, sans-serif",
        "weights": [400, 700]
      }
    },
    "base": {
      "size": "16px",
      "lineHeight": "1.6"
    },
    "scales": {
      "h1": { "desktop": "36px", "mobile": "34.2px", "weight": 700 },
      "h2": { "desktop": "28px", "mobile": "26.6px", "weight": 700 },
      "h3": { "desktop": "22px", "weight": 700 },
      "h4": { "desktop": "20px", "weight": 700 },
      "h5": { "desktop": "18px", "weight": 700 },
      "body": { "desktop": "16px", "weight": 300 }
    }
  },
  "spacing": {
    "base": "20px",
    "grid": "30px",
    "block": "40px",
    "section": {
      "small": "40px",
      "default": "70px",
      "large": "140px",
      "xl": "210px"
    }
  },
  "borders": {
    "radius": "0px",
    "styles": {
      "handDrawn": "SVG-based border-image used for sketched look"
    }
  },
  "shadows": {
    "default": "0 2px 8px rgba(0,0,0,.08)"
  }
}
