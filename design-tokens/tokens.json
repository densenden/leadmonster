{
  "_source": "Derived from finanzteam26.de — official brand reference site",
  "colors": {
    "brand": {
      "cyan": {
        "DEFAULT": "#02a9e6",
        "name": "Brand Cyan",
        "usage": "Primary accent — icons, buttons, highlights, hover states, links"
      },
      "cyan_light": {
        "DEFAULT": "#e1f0fb",
        "name": "Cyan Light",
        "usage": "Section backgrounds, info boxes, tag backgrounds"
      },
      "orange": {
        "DEFAULT": "#f26522",
        "name": "Brand Orange",
        "usage": "Secondary accent — CTA buttons, badges, numeric emphasis (the '26')"
      },
      "orange_dark": {
        "DEFAULT": "#d4511a",
        "name": "Orange Dark",
        "usage": "Orange button hover state"
      },
      "navy": {
        "DEFAULT": "#1a3252",
        "name": "Navy Dark",
        "usage": "Headings, nav backgrounds, footer, primary dark surfaces"
      },
      "navy_mid": {
        "DEFAULT": "#2c5282",
        "name": "Navy Mid",
        "usage": "Secondary dark surfaces, nav hover"
      }
    },
    "text": {
      "heading": "#1a3252",
      "body": "#4a5568",
      "muted": "#718096",
      "inverse": "#ffffff"
    },
    "background": {
      "page": "#ffffff",
      "muted": "#f7fafc",
      "brand": "#e1f0fb",
      "dark": "#1a3252"
    },
    "border": {
      "default": "#e2e8f0",
      "brand": "#02a9e6",
      "strong": "#1a3252"
    },
    "status": {
      "success": "#38a169",
      "warning": "#d69e2e",
      "error": "#e53e3e",
      "info": "#02a9e6"
    }
  },
  "typography": {
    "fonts": {
      "body": {
        "family": "'Nunito Sans', sans-serif",
        "weights": [300, 400, 600],
        "google": "https://fonts.google.com/specimen/Nunito+Sans"
      },
      "heading": {
        "family": "'Roboto', sans-serif",
        "weights": [400, 700],
        "google": "https://fonts.google.com/specimen/Roboto"
      }
    },
    "base": {
      "size": "16px",
      "lineHeight": "1.6"
    },
    "scales": {
      "h1": { "desktop": "36px", "mobile": "28px", "weight": 700, "lineHeight": "1.15" },
      "h2": { "desktop": "28px", "mobile": "22px", "weight": 700, "lineHeight": "1.2" },
      "h3": { "desktop": "22px", "mobile": "18px", "weight": 700, "lineHeight": "1.3" },
      "h4": { "desktop": "18px", "weight": 700, "lineHeight": "1.4" },
      "h5": { "desktop": "16px", "weight": 600, "lineHeight": "1.4" },
      "body": { "desktop": "16px", "weight": 300, "lineHeight": "1.7" },
      "small": { "desktop": "14px", "weight": 400, "lineHeight": "1.5" }
    }
  },
  "spacing": {
    "base": "20px",
    "grid": "30px",
    "block": "40px",
    "section": {
      "sm": "40px",
      "md": "70px",
      "lg": "100px",
      "xl": "140px"
    },
    "container": {
      "max_width": "1200px",
      "padding": "24px"
    }
  },
  "borders": {
    "radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "full": "9999px"
    },
    "width": "1px",
    "button": "1.5px"
  },
  "shadows": {
    "sm": "0 1px 3px rgba(0,0,0,.08)",
    "md": "0 4px 12px rgba(0,0,0,.10)",
    "lg": "0 8px 24px rgba(0,0,0,.12)"
  },
  "buttons": {
    "style": "outline",
    "note": "Default buttons are border/outline style — transparent bg, colored border+text, fill on hover",
    "variants": {
      "primary": {
        "border_color": "#02a9e6",
        "text_color": "#02a9e6",
        "hover_bg": "#02a9e6",
        "hover_text": "#ffffff"
      },
      "secondary": {
        "border_color": "#1a3252",
        "text_color": "#1a3252",
        "hover_bg": "#1a3252",
        "hover_text": "#ffffff"
      },
      "accent": {
        "border_color": "#f26522",
        "text_color": "#f26522",
        "hover_bg": "#f26522",
        "hover_text": "#ffffff"
      },
      "inverse": {
        "border_color": "#ffffff",
        "text_color": "#ffffff",
        "hover_bg": "#ffffff",
        "hover_text": "#1a3252"
      }
    },
    "padding": {
      "sm": "6px 16px",
      "md": "10px 24px",
      "lg": "14px 32px"
    },
    "font_weight": 600,
    "letter_spacing": "0.02em",
    "transition": "all 0.2s ease"
  },
  "icons": {
    "source": "finanzteam26.de UIKit icons",
    "primary_color": "#02a9e6",
    "primary_opacity": 0.25,
    "detail_color": "#333333",
    "detail_opacity": 0.9,
    "size": "110x110",
    "files": {
      "beratung": "/icons/icon-beratung.svg",
      "schutz": "/icons/icon-schutz.svg",
      "vorsorge": "/icons/icon-vorsorge.svg",
      "familie": "/icons/icon-familie.svg",
      "altersvorsorge": "/icons/icon-altersvorsorge.svg"
    }
  },
  "images": {
    "team": "/images/team.jpg",
    "hero_students": "/images/hero-students.jpg",
    "hero_teacher": "/images/hero-teacher.jpg",
    "hero_startup": "/images/hero-startup.jpg",
    "piggy_bank": "/images/piggy-bank.png",
    "ft26_logo": "/images/ft26-logo.svg"
  }
}
