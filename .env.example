# Anthropic Claude API
ANTHROPIC_API_KEY=

# Supabase — Keys unter: Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Base URL
NEXT_PUBLIC_BASE_URL=
# Required — absolute base URL, e.g. https://leadmonster.de

# Internal
INTERNAL_SECRET=
# Required — shared secret for internal API-to-API calls

# Resend — transactional email
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=
# Must be a verified sender domain in your Resend account (e.g. noreply@yourdomain.de)
RESEND_FROM_ADDRESS=
# Sales team email address to receive new lead notifications
SALES_NOTIFICATION_EMAIL=

# Confluence — Fallback falls noch kein DB-Eintrag vorhanden
# Wird im Admin-Bereich pro Account überschreibbar (gespeichert in DB-Tabelle: einstellungen)
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=
CONFLUENCE_PARENT_PAGE_ID=

# Unsplash (Stock-Bilder)
UNSPLASH_ACCESS_KEY=
