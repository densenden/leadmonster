# =============================================================================
# LeadMonster — Environment Variables Template
# Kopiere diese Datei nach .env.local und fülle die Werte ein.
# Niemals echte Secrets in dieses File!
# =============================================================================

# Anthropic Claude API — Content-Generierung
ANTHROPIC_API_KEY=

# OpenAI — Bildgenerierung (gpt-image-1)
OPENAI_API_KEY=

# Supabase — Project Settings → API Keys + Database → Connection string
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
DATABASE_URL=
# DATABASE_URL Format: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Base URL für absolute URLs (Schema.org, Sitemap, OG-Bilder)
NEXT_PUBLIC_BASE_URL=
# Required — z.B. https://leadmonster.de oder https://leadmonster.vercel.app

# Internal API-zu-API Auth
INTERNAL_SECRET=
# Required — shared secret für internal Endpoints (z.B. /api/seo/llms)

# Resend — Transaktionale E-Mails (Lead-Bestätigung + Sales-Notification)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=
# Verified sender domain in Resend (z.B. noreply@yourdomain.de)
SALES_NOTIFICATION_EMAIL=
# Vertriebs-Mail für Lead-Notifications

# Convexa — CRM (Lead-Sync nach Form-Submit)
# Skeleton-Adapter funktioniert auch ohne Token — Leads landen mit
# convexa_synced=false in DB; Re-Sync später via Admin möglich.
CONVEXA_BASE_URL=
# Default: https://app.convexa.app
CONVEXA_API_TOKEN=
CONVEXA_WORKSPACE_ID=

# Confluence — DEAKTIVIERT seit Convexa-Pivot (April 2026)
# Optionale Fallback-Konfig für Re-Sync legacy Leads.
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=
CONFLUENCE_PARENT_PAGE_ID=

# Unsplash — Optional, für Stock-Bilder als Fallback zu KI
UNSPLASH_ACCESS_KEY=
